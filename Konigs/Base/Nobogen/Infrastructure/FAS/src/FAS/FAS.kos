define(
    @FAS_Init;
    f() Kog_Result;
    function(
        f() Kog_Result;
        return(
            const(Kog_Result; @Kog_ResultGood)
        )
    )
);

define(
    @FAS_Quit;
    f() Kog_Result;
    function(
        f() Kog_Result;
        return(
            const(Kog_Result; @Kog_ResultGood)
        )
    )
);