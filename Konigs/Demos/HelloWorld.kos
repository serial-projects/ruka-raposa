define(
    @main;
    f() nothing;
    function(
        f() nothing;
        return(
            call(@Kog_SystemConsoleIOPrint; const(string; "Hello World"));
            call(@Kog_SystemProgramExitCodeSet; const(u8; 0));
            const(nothing; nothing)
        )
    )
)